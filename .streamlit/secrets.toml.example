# Copy this file to `.streamlit/secrets.toml` and fill in your values.
# `.streamlit/secrets.toml` is git-ignored; never commit real keys.
#
# Naver CLOVA Speech (long-sentence recognition) credentials.
# Get these from the NCP console:
#   AI·NAVER API > CLOVA Speech > Domain > Run builder > Settings tab
# Copy the Invoke URL verbatim (do not append a path) and the domain Secret Key.

CLOVA_SPEECH_INVOKE_URL = "https://clovaspeech-gw.ncloud.com/external/v1/<invokeId>/<key>"
CLOVA_SPEECH_SECRET = "<X-CLOVASPEECH-API-KEY secret key>"

# Optional overrides:
# CLOVA_SPEECH_LANGUAGE = "ko-KR"   # ko-KR | en-US | enko | ja | zh-cn | zh-tw
# CLOVA_SPEECH_TIMEOUT = "60"       # seconds

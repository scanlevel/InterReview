# Copy to .env and fill in. .env is git-ignored.

# Frontend origins allowed to call this API (comma-separated).
CORS_ORIGINS=http://localhost:3000

# --- CLOVA Speech (STT) ---
CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_SECRET=
CLOVA_SPEECH_LANGUAGE=ko-KR
# HTTP wait for CLOVA's response, in seconds (not an answer-length limit).
# Optional — omit to use the default (180). Raise it if long answers time out.
CLOVA_SPEECH_TIMEOUT=180

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=
EVAL_MODEL=claude-sonnet-5
PERSONALIZE_MODEL=claude-haiku-4-5-20251001
